{
  "version": 3,
  "routes": [
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "headers": {
        "Content-Type": "application/xslt+xml"
      },
      "src": "/__sitemap__/style.xsl"
    },
    {
      "headers": {
        "X-Robots-Tag": "noindex"
      },
      "src": "/_nuxt"
    },
    {
      "headers": {
        "X-Robots-Tag": "noindex"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nitro"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml?url=$url"
    },
    {
      "src": "/(.*)",
      "dest": "/__nitro"
    }
  ],
  "overrides": {
    "index.html": {
      "path": ""
    }
  },
  "framework": {
    "version": "3.15.4"
  },
  "crons": []
}
